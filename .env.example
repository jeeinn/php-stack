# PHP-Stack 环境配置文件
# 复制此文件为 .env 并修改配置
#
# 注意：Docker Daemon 的 registry-mirrors 由 Docker Desktop 设置管理
#       或在 src-tauri/src/docker/mirror.rs 中配置

# ==================== 容器内依赖镜像源 ====================
# 用于加速容器内的 apt-get、composer、pip、npm 等命令

# APT 软件源（Debian/Ubuntu）
# 可选值: default, aliyun, tsinghua, ustc
APT_MIRROR=aliyun

# Composer 镜像源
# 可选值: default, aliyun, huaweicloud
COMPOSER_MIRROR=aliyun

# PyPI 镜像源（pip install）
# 可选值: default, aliyun, tsinghua
PYPI_MIRROR=aliyun

# NPM 镜像源
# 可选值: default, taobao, tencent
NPM_MIRROR=taobao

# ==================== Docker 构建代理 ====================

# HTTP 代理（可选，留空则不使用）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 不使用代理的地址（逗号分隔）
# NO_PROXY=localhost,127.0.0.1,.local
